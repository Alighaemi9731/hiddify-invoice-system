# ============================================================================
#  Hiddify Reseller Invoicing System — bootstrap config
#  Copy to `.env` and fill in. `.env` is gitignored and must NEVER be committed.
#  These are ONLY bootstrap values; once running, most settings are editable
#  from the web panel (stored in the DB `settings` table).
# ============================================================================

# ---- App ----
APP_ENV=local
# Used to sign JWTs AND to encrypt secret fields at rest (panel API keys, bot
# token, wallet xpub). Generate one: `python -c "import secrets;print(secrets.token_urlsafe(48))"`
SECRET_KEY=change-me-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=720

# Initial owner login for the web panel (seeded on first boot only).
ADMIN_USERNAME=owner
ADMIN_PASSWORD=change-me-now

# ---- Database (PostgreSQL in docker-compose) ----
POSTGRES_USER=invoice
POSTGRES_PASSWORD=invoice
POSTGRES_DB=invoice
POSTGRES_HOST=db
POSTGRES_PORT=5432
# Full URL overrides the parts above if set. For a quick local run without
# Postgres you may use: sqlite+aiosqlite:///./data/app.db
# DATABASE_URL=postgresql+asyncpg://invoice:invoice@db:5432/invoice

# ---- Telegram bot (bootstrap; also editable in the panel) ----
TELEGRAM_BOT_TOKEN=
# Channel resellers must join before using the bot (id like -100xxxxxxxxxx).
ANNOUNCEMENT_CHANNEL_ID=
ANNOUNCEMENT_CHANNEL_LINK=

# ---- Payments (BEP-20 USDT) — editable in the panel too ----
# Shared receiving address for the MVP TXID flow.
USDT_BEP20_ADDRESS=
# USDT (BSC) contract — default is the canonical Binance-Peg USDT.
USDT_BEP20_CONTRACT=0x55d398326f99059fF775485246999027B3197955
BSCSCAN_API_KEY=
# Optional, for the later HD-wallet per-reseller deposit-address upgrade.
USDT_MASTER_XPUB=

# ---- Pricing ----
DEFAULT_PRICE_PER_GB_TOMAN=1000
# Toman per 1 USDT. Editable in the panel (manual or auto rate).
TOMAN_PER_USDT=70000

# ---- Frontend ----
# Where the SPA reaches the API (used at build/runtime).
VITE_API_BASE_URL=http://localhost:8000
