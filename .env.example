# ============================================================================
#  Hiddify Reseller Invoicing System — bootstrap config (REFERENCE ONLY)
#  The installer (get.sh / deploy/install.sh) generates the real `.env` for you;
#  you normally never edit this by hand. `.env` is gitignored and must NEVER be
#  committed. These are ONLY bootstrap values; once running, all other settings
#  are edited from the web panel (stored in the DB `settings` table).
# ============================================================================

# ---- App ----
APP_ENV=production
# Used to sign JWTs AND to encrypt secret fields at rest (panel API keys, bot
# token, wallet xpub). Generate one: `python -c "import secrets;print(secrets.token_urlsafe(48))"`
SECRET_KEY=change-me-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=720

# Initial owner login. Leave ADMIN_PASSWORD EMPTY to use the in-browser first-run
# setup wizard (recommended). Set it only to skip the wizard for a scripted install.
ADMIN_USERNAME=owner
ADMIN_PASSWORD=

# ---- Database (PostgreSQL) ----
POSTGRES_USER=invoice
POSTGRES_PASSWORD=change-me
POSTGRES_DB=invoice
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://invoice:change-me@db:5432/invoice

# ---- Telegram bot (bootstrap; also editable in the panel) ----
TELEGRAM_BOT_TOKEN=
# Channel resellers must join before using the bot (id like -100xxxxxxxxxx).
ANNOUNCEMENT_CHANNEL_ID=
ANNOUNCEMENT_CHANNEL_LINK=

# ---- Payments (BEP-20 USDT) — editable in the panel too ----
# Shared receiving address for the MVP TXID flow.
USDT_BEP20_ADDRESS=
# USDT (BSC) contract — default is the canonical Binance-Peg USDT.
USDT_BEP20_CONTRACT=0x55d398326f99059fF775485246999027B3197955
BSCSCAN_API_KEY=
# Optional, for the later HD-wallet per-reseller deposit-address upgrade.
USDT_MASTER_XPUB=

# ---- Pricing ----
DEFAULT_PRICE_PER_GB_TOMAN=1000
# Toman per 1 USDT. Editable in the panel (manual or auto rate).
TOMAN_PER_USDT=70000

# ---- Deployment ----
# Public domain for automatic HTTPS (leave empty → reachable at http://<server-ip>,
# then set the domain in the first-run wizard or the panel). Email for Let's Encrypt.
SERVER_DOMAIN=
ACME_EMAIL=
