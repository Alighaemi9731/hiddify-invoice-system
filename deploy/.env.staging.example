APP_ENV=staging
SECRET_KEY=replace-with-a-random-staging-only-key
ACCESS_TOKEN_EXPIRE_MINUTES=60

ADMIN_USERNAME=staging
ADMIN_PASSWORD=replace-with-a-staging-only-password

POSTGRES_USER=invoice_staging
POSTGRES_PASSWORD=replace-with-a-staging-only-db-password
POSTGRES_DB=invoice_staging
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://invoice_staging:replace-with-a-staging-only-db-password@db:5432/invoice_staging

RUN_SCHEDULER=false
STAGING_PORT=18080
